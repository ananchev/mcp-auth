# Copy to deploy/.env (gitignored) and fill in. NEVER commit the real .env.

# Public origin = the OAuth issuer. Use a SINGLE-LABEL host under your domain so
# Cloudflare Universal SSL covers it (2-level subdomains aren't covered). Must be the
# real external URL — if left at localhost, claude.ai follows dead discovery URLs.
MCP_PUBLIC_URL=https://mcp-auth.example.com

# Operator identity shown on the password consent form. Both required.
MCP_OAUTH_USER=
MCP_OAUTH_PASSWORD=

# HS256 signing secret: openssl rand -hex 32
# MUST equal each Resource Server's MCP_OAUTH_SIGNING_KEY (e.g. sleep-mcp).
MCP_OAUTH_SIGNING_KEY=

# Access-token lifetime (short) and refresh-token lifetime (long).
MCP_OAUTH_TOKEN_TTL=1h
MCP_OAUTH_REFRESH_TTL=720h

# Exact allowed redirect URIs (comma-separated). Loopback is always allowed.
MCP_OAUTH_ALLOWED_REDIRECTS=https://claude.ai/api/mcp/auth_callback

# Host port to publish on the Docker host's LAN (NPM forwards here).
AUTH_PORT=8092
