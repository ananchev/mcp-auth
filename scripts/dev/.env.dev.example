# Copy to scripts/dev/.env.dev (gitignored) and fill in. Used by run-local.sh + npm-flip.sh.

# ─── Laptop reachability (for the flip) ───────────────────────────────────────
# Space-separated IPv4 prefixes; run-local.sh picks the first matching local IP.
LAPTOP_SUBNETS="192.168.2.5 10.8.0."

# ─── NPM API (for the dev upstream flip) ──────────────────────────────────────
NPM_BASE_URL=http://fed:81
NPM_API_USER='you@example.com'
NPM_API_PASSWORD=
# Proxy-host ID in NPM for mcp-auth.example.com (create the proxy host first, then read
# its id — e.g. the NN in /opt/docker/nginx-proxy-manager/data/nginx/proxy_host/NN.conf).
NPM_MCPAUTH_PROXY_ID=
# The normal (prod) upstream NPM points at when NOT flipped (the Docker host LAN IP).
PROD_FORWARD_HOST=192.168.2.2

# ─── AS runtime (read by the server process) ──────────────────────────────────
# Public origin = OAuth issuer. For the flipped test this is the real public host,
# because claude.ai reaches it via CF→NPM→laptop.
MCP_PUBLIC_URL=https://mcp-auth.example.com
MCP_HTTP_ADDR=:8092
MCP_OAUTH_USER=
MCP_OAUTH_PASSWORD=
# Generate: openssl rand -hex 32. Must MATCH sleep-mcp's MCP_OAUTH_SIGNING_KEY.
MCP_OAUTH_SIGNING_KEY=
MCP_OAUTH_TOKEN_TTL=1h
MCP_OAUTH_REFRESH_TTL=720h
MCP_OAUTH_ALLOWED_REDIRECTS=https://claude.ai/api/mcp/auth_callback
# Local refresh store (gitignored); /data/refresh.json in Docker.
MCP_OAUTH_REFRESH_STORE=./refresh.json
