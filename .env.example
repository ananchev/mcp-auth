# Copy to .env and fill in. NEVER commit the real .env.

# Public origin of THIS authorization server (the OAuth issuer). Must be the real
# external URL — if left at localhost, claude.ai follows dead discovery URLs.
MCP_PUBLIC_URL=https://mcp-auth.example.com

# Listen address inside the container/host.
MCP_HTTP_ADDR=:8092

# The single operator identity. Both required once MCP_OAUTH_SIGNING_KEY is set.
MCP_OAUTH_USER=
MCP_OAUTH_PASSWORD=

# HMAC signing secret for HS256 access tokens. Generate: openssl rand -hex 32
# Every Resource Server that trusts this AS must hold the SAME value.
MCP_OAUTH_SIGNING_KEY=

# Access-token lifetime (short) and refresh-token lifetime (long).
MCP_OAUTH_TOKEN_TTL=1h
MCP_OAUTH_REFRESH_TTL=720h

# Exact allowed redirect URIs (comma-separated). Loopback is always allowed.
# claude.ai web connector uses this exact value (no trailing slash):
MCP_OAUTH_ALLOWED_REDIRECTS=https://claude.ai/api/mcp/auth_callback

# File-backed refresh-token store (mount /data as a volume so it survives deploys).
MCP_OAUTH_REFRESH_STORE=/data/refresh.json
